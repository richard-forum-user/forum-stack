{
  "name": "zk-solid-vault",
  "version": "2.0.0",
  "description": "ZK Passport → Solid Pod (containerised) → AI-managed SQLite (sandboxed) → Signed+Encrypted export → Async Mistral GPU analysis",
  "main": "dist/pod-provisioner.js",
  "bin": {
    "provision-pod": "./dist/pod-provisioner.js",
    "analysis-worker": "./dist/analysis-queue.js"
  },
  "scripts": {
    "build":            "tsc",
    "start":            "node dist/pod-provisioner.js",
    "server":           "node dist/server-receiver.js",
    "worker":           "node dist/analysis-queue.js worker",
    "keygen":           "node -e \"require('./dist/secure-export').generateKeyPair()\"",
    "dev":              "ts-node src/pod-provisioner.ts",
    "dev:server":       "ts-node src/server-receiver.ts",
    "dev:worker":       "ts-node src/analysis-queue.ts worker",
    "dev:frontend":     "vite frontend",
    "deploy:worker":    "wrangler deploy src/cf-worker.ts",
    "docker:network":   "docker network create --driver bridge --internal pod-network || true"
  },
  "dependencies": {
    "@rarimo/zk-passport":                       "^1.1.2",
    "@solid/community-server": "^7.1.0",
    "better-sqlite3":                            "^9.6.0",
    "node-llama-cpp":                            "^3.3.0",
    "express":                                   "^4.21.0",
    "bullmq":                                    "^5.0.0",
    "ioredis":                                   "^5.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3":  "^7.6.0",
    "@types/express":         "^4.17.0",
    "@types/node":            "^20.0.0",
    "typescript":             "^5.5.0",
    "ts-node":                "^10.9.0",
    "vite":                   "^5.0.0",
    "@vitejs/plugin-react":   "^4.0.0",
    "wrangler":               "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
