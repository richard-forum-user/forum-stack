[Unit]
Description=Forum Airlock Listener
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/Desktop/forum-airlock
EnvironmentFile=%h/Desktop/forum.config.env
ExecStart=/usr/bin/node %h/Desktop/forum-airlock/listener.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
