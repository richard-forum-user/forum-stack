# Copy to forum.config.env and fill in values for local development.
# Used by forum-airlock/listener, forum-ai/run_analysis.sh, and forum-ai/push.py

# Different values — do not copy one into the other.
AIRLOCK_SECRET=your-airlock-shared-secret
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-44-char-url-safe-fernet-key-with-equals-sign

# Local sovereign node (forum-airlock/listener.js)
LISTENER_URL=http://127.0.0.1:3000

# Public phone/PWA deployment hostnames. The Worker serves POD_PUBLIC_URL.
# The Worker reaches your local listener through LISTENER_PUBLIC_URL.
POD_PUBLIC_URL=https://pod.yourcommunity.forum
LISTENER_PUBLIC_URL=https://listener.yourcommunity.forum

# Cloudflare egress worker (forum-egress) — leave empty to skip cloud push
FORUM_EGRESS_URL=https://forum-egress.yourcommunity.forum
FORUM_SECRET=match-cloudflare-dashboard-FORUM_SECRET

# Auto-run classify+aggregate after each civic submit (heavy; off by default)
FORUM_AUTO_ANALYSIS=0

# Pod AI chat fallback when browser has no WebGPU (forum-pod → Ollama)
OLLAMA_PORT=11434

# Optional for a separately hosted pod. Same-origin /api/civic/submit is the default.
# Android app builds should set VITE_SERVER_URL or enter it in the app Settings tab.
# VITE_SERVER_URL=https://pod.yourcommunity.forum
# VITE_CIVIC_API=https://yourcommunity.forum/api/civic/submit
# VITE_OLLAMA_MODEL=smart-analyst
