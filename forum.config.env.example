# Copy to forum.config.env only for local experiments with archived on-prem
# code. The live edge stack uses Wrangler secrets and vars instead.

# Worker API secret for protected analysis endpoints:
#   POST /api/civic/analysis/run
#   POST /api/civic/analysis/publish
# Upload with: npx wrangler secret put AIRLOCK_SECRET
AIRLOCK_SECRET=your-airlock-shared-secret

# Cloudflare egress Worker (forum-egress) used by edge civic analysis.
# Upload both with wrangler secret put on secure-worker.
FORUM_EGRESS_URL=https://forum-egress.yourcommunity.forum
FORUM_SECRET=match-cloudflare-dashboard-FORUM_SECRET

# Optional for a separately hosted Pod app.
# Android app builds should set VITE_SERVER_URL or enter it in the app Settings tab.
# VITE_SERVER_URL=https://secure-worker.forum-community.workers.dev
