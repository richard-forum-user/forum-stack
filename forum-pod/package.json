{
  "name": "forum-pod",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "vendor:civic-ai": "node scripts/vendor-civic-ai.mjs",
    "build": "npm run vendor:civic-ai && vite build",
    "build:pwa": "npm run vendor:civic-ai && VITE_BASE=/pod/ vite build",
    "build:android": "npm run vendor:civic-ai && VITE_BASE=./ vite build && npx cap sync android",
    "android:add": "npx cap add android",
    "android:open": "npx cap open android",
    "android:apk": "npm run vendor:civic-ai && VITE_BASE=./ vite build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.33.1-dev45.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@capacitor/android": "6.2.1",
    "@capacitor/cli": "6.2.1",
    "@capacitor/core": "6.2.1",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
