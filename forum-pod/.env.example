# Forum Personal Pod — ownership-by-default configuration.
#
# Leave VITE_SERVER_URL empty for the recommended setup:
#
#   * Desktop installer (Tauri) — webview points at the bundled workerd
#     on http://127.0.0.1:8787 automatically.
#   * Android / iOS app — uses the on-device SQLite Pod (no network).
#   * Plain browser preview — falls back to same-origin.
#
# Only set VITE_SERVER_URL if you have your own Cloudflare Worker
# hosting the Pod (e.g. self-hosted on your own account, or you are
# trying the cooperative trial pod).
VITE_SERVER_URL=
VITE_POD_PROVIDER_URL=

# Cooperative trial pod (opt-in). Users who tap "Try without installing"
# in the welcome flow get routed here for 7 days, with a banner asking
# them to graduate to a local install.
VITE_TRIAL_POD_URL=https://airlock.yourcommunity.forum

# Cooperative pipeline — opt-in civic export only (leave empty to hide
# share UI).
VITE_COOP_URL=https://coop.yourcommunity.forum

VITE_FORUM_FEEDBACK_API=/api/forum/feedback
