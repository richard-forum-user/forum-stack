# ============================================================================
# forum-stack monorepo .gitignore
# ============================================================================
# Per-folder .gitignore files inside forum-pod/ and forum-airlock/ stay as
# additional layers. Patterns here are the floor.
# ============================================================================

# -----------------------------------------------------------------------------
# Secrets — never commit
# -----------------------------------------------------------------------------
*.env
**/.env
**/.env.*
!**/.env.example
!**/.env.sample
**/forum.config.env
*.pem
*.key
*-private*
*.tunnel.json
.dev.vars

# Explicit: forum-ai/Keys is a no-extension plaintext secret bundle
# (FERNET_KEY, AIRLOCK_SECRET, HASH_PEPPER, TURNSTILE_SECRET, RSA private key).
forum-ai/Keys

# -----------------------------------------------------------------------------
# User / encrypted data — never commit
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
forum_inbound*
members_email_hashes*.csv

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
*.local
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# Android (Capacitor) generated artifacts
**/android/app/build/
**/android/build/
**/android/.gradle/
**/android/local.properties
**/android/app/release/
**/android/captures/

# -----------------------------------------------------------------------------
# Cloudflare Wrangler
# -----------------------------------------------------------------------------
.wrangler/

# -----------------------------------------------------------------------------
# APK / signing artifacts
# -----------------------------------------------------------------------------
*.apk
*.aab
*.keystore
*.jks

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
cron.log

# -----------------------------------------------------------------------------
# Aider / IDE clutter
# -----------------------------------------------------------------------------
.aider*
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.AppImage

# -----------------------------------------------------------------------------
# Egress runtime data (regenerated by forum-ai/push.py)
# -----------------------------------------------------------------------------
forum-egress/report.json
